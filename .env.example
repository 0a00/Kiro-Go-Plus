ADMIN_PASSWORD=replace-with-a-strong-random-password
LOG_LEVEL=info
# Host port published by Compose; the container listener remains on 8080.
KIRO_PORT=8080
PUID=1000
PGID=1000
# Emergency-only escape hatch for a public bind using the default password.
ALLOW_INSECURE_PUBLIC_BIND=false
# Public API routes fail closed without API-key enforcement unless explicitly enabled.
ALLOW_UNAUTHENTICATED_API=false
# Generate with: openssl rand -base64 32
# Keep this value stable; losing it makes encrypted credentials and Responses history unrecoverable.
KIRO_MASTER_KEY=
# Comma-separated regions probed for Microsoft 365 / Entra ID Kiro profiles.
KIRO_PROFILE_REGIONS=us-east-1,eu-central-1
